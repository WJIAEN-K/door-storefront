generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id             String  @id @default(cuid())
  slug           String  @unique
  sku            String
  msgKey         String
  name           String
  nameZh         String?
  categorySlug   String
  categoryName   String
  categoryNameZh String?
  priceRange     String
  rating         Int
  reviews        Int
  leadTime       String
  leadTimeZh     String?
  finish         String
  finishZh       String?
  size           String
  sizeZh         String?
  material       String
  materialZh     String?
  installation   String
  installationZh String?
  description    String
  descriptionZh  String?
  highlights     String
  highlightsZh   String?
  specs          String
  specsZh        String?
  visual         String
  imageFolder    String
  imageFile      String
  galleryFiles   String
  featured       Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Article {
  id               String    @id @default(cuid())
  slug             String    @unique
  titleEn          String
  titleZh          String
  bodyMarkdown     String    @default("")
  coverImageUrl    String    @default("")
  published        Boolean   @default(false)
  publishedAt      DateTime?
  showInCarousel   Boolean   @default(false)
  carouselSort     Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}
